# ─── AI 백엔드 ─────────────────────────────────────────────
# 텍스트·이미지 모두 기본은 CLI(구독) — 아래 API 키는 'api' 모드일 때만 필요.
#   텍스트: Claude = `claude` CLI, GPT = `codex` CLI (둘 다 구독, 키 불필요)
#   이미지: `gti` CLI (god-tibo-imagen, codex 구독 세션, 키 불필요)

# CLI ↔ API 전환 스위치 (기본 cli)
CLAUDE_BACKEND=cli                    # cli(구독) | api(ANTHROPIC_API_KEY 필요)
OPENAI_BACKEND=cli                    # cli(codex 구독) | api(OPENAI_API_KEY 필요)
OPENAI_IMAGE_BACKEND=cli              # cli(gti, 키 불필요) | api(gpt-image-2, 키 필요)

# ─── API Keys (위에서 api 모드를 켰을 때만 필요) ───────────
ANTHROPIC_API_KEY=sk-ant-...          # CLAUDE_BACKEND=api 일 때만
OPENAI_API_KEY=sk-...                 # OPENAI_BACKEND=api 또는 OPENAI_IMAGE_BACKEND=api 일 때만

# ─── Model IDs (선택 override) ─────────────────────────────
CLAUDE_MODEL=claude-opus-4-6          # default
OPENAI_MODEL=gpt-4o                   # API 모드 텍스트 모델
OPENAI_CLI_MODEL=                     # codex 모델 override (비우면 codex 기본)
OPENAI_IMAGE_MODEL=gpt-image-2        # OPENAI_IMAGE_BACKEND=api 일 때 이미지 모델
OPENAI_IMAGE_CLI_MODEL=               # gti --model override (비우면 gti 기본)
OPENAI_IMAGE_CLI_PROVIDER=private-codex  # gti --provider (Windows는 private-codex 권장)
OPENAI_SYNTHESIS_ENGINE=claude        # 조율 종합 엔진 (default: claude)

# ─── App Settings ──────────────────────────────────────────
STORAGE_SECRET=daangn-ad-reporter-change-me
